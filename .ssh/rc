#!/bin/bash
# Update the stable agent socket symlink on every SSH connection.
# This ensures that existing tmux sessions (which reference this path)
# pick up the new forwarded agent after autossh reconnects.
if [ -n "$SSH_AUTH_SOCK" ] && [ "$SSH_AUTH_SOCK" != "$HOME/.agent-sshtmux-$USER.sock" ]; then
    if [ -S "$SSH_AUTH_SOCK" ]; then
        ln -sf "$SSH_AUTH_SOCK" "$HOME/.agent-sshtmux-$USER.sock"
    fi
fi
